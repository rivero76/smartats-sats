# ── Supabase (required) ────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_PROJECT_ID=<project-ref>
SUPABASE_SERVICE_KEY=<service-role-key>      # Required for admin log queries (fetch-logs.sh)
SUPABASE_ACCESS_TOKEN=<personal-access-token> # Required for platform log queries (fetch-logs.sh)

# ── Frontend logging (optional) ────────────────────────────────────────────────
VITE_LOGGING_ENABLED=true
VITE_LOG_SAMPLE_DEBUG_RATE=0.1
VITE_LOG_SAMPLE_TRACE_RATE=0.05

# ── LLM Provider — edge functions (required for AI features) ───────────────────
SATS_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# ── LLM model overrides (optional — defaults set per edge function) ─────────────
OPENAI_MODEL_ATS=gpt-4.1
OPENAI_TEMPERATURE_ATS=0.2
OPENAI_MAX_TOKENS_ATS=1500
OPENAI_MODEL_ENRICH=gpt-4.1-mini
OPENAI_MAX_TOKENS_ENRICH=1000

# ── Privacy / storage flags (optional) ────────────────────────────────────────
STORE_LLM_PROMPTS=false
STORE_LLM_RAW_RESPONSE=false

# ── CORS — edge functions (required for local dev) ────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── External job APIs — P14/P16 (required for live job discovery) ─────────────
RAPID_API_KEY=<rapidapi-key>          # JSearch (US/global jobs via RapidAPI)
ADZUNA_APP_ID=<adzuna-app-id>         # Adzuna (BR/AU/NZ/UK jobs)
ADZUNA_API_KEY=<adzuna-api-key>
